# FarmacoGraph environment configuration
# Copy to .env and adjust for your environment.
# On the production host prefer: ./scripts/deploy-production.sh (writes .env safely).

# Canonical app mode (API Settings.environment). Alias FG_ENV is only read by deploy-production.sh.
FG_ENVIRONMENT=development
# FG_ENV=development
FG_DEBUG=false
FG_DATABASE_URL=sqlite+aiosqlite:///./farmacograph_ops.db
# FG_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/farmacograph

FG_NEO4J_ENABLED=false
FG_NEO4J_URI=bolt://localhost:7687
FG_NEO4J_USER=neo4j
FG_NEO4J_PASSWORD=password

# Required non-default in production (API refuses insecure defaults when FG_ENVIRONMENT=production)
FG_JWT_SECRET_KEY=change-me-in-production-use-long-random-string
FG_LOG_LEVEL=INFO
FG_LOG_JSON=false
FG_METRICS_ENABLED=true

# Docker host ports (run ./scripts/find-ports.sh --apply to auto-set)
# FG_HOST_PG_PORT=5433
# FG_HOST_NEO4J_HTTP_PORT=7474
# FG_HOST_NEO4J_BOLT_PORT=7687
# FG_HOST_API_PORT=8001
# FG_HOST_STUDIO_PORT=3001

# Curation Studio — Docker *build args* (baked into the Next.js client bundle).
# Changing these requires: docker compose build --no-cache studio && docker compose up -d studio
# Do NOT use localhost / 127.0.0.1 / host.docker.internal here for production images.
# Set by ./scripts/deploy-production.sh on the server:
# FG_STUDIO_API_URL=https://farmacograph.furkanguven.space/api/v1
# FG_STUDIO_BASE_PATH=/studio
# FG_SEED_DEV_USERS=false
