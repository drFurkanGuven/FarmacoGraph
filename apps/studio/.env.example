# Local `npm run dev` / `npm run build` only (NOT used by Docker — see root .env FG_STUDIO_*).
# Docker production images must bake a public https API URL via compose build args.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8001/api/v1

# Production / nginx path prefix (leave unset for bare localhost:3000 during local npm).
# NEXT_PUBLIC_BASE_PATH=/studio

# Optional: pre-configured API key for development
# NEXT_PUBLIC_API_KEY=
